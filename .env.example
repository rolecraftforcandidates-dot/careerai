# ── Google Sheets ──
SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Session ──
SESSION_SECRET=rolecraft-secret-change-this-to-something-random

# ── Environment ──
NODE_ENV=production

# ── Anthropic (Claude AI) ──
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail (for welcome emails) ──
GMAIL_USER=yourgmail@gmail.com
# NOT your Gmail password — create an App Password:
# Gmail → Settings → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Dashboard URL (used in welcome email link) ──
DASHBOARD_URL=https://your-app.railway.app

# ── Tally Webhook Secret (optional) ──
TALLY_WEBHOOK_SECRET=rolecraft-tally-secret-2025
