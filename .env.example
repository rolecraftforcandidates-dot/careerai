# ── Google Sheets ──
SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Session ──
SESSION_SECRET=rolecraft-secret-change-this-to-something-random

# ── Environment ──
NODE_ENV=production

# ── Anthropic (Claude AI) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Email — Brevo SMTP (free, 300 emails/day, works on Railway) ──
# Sign up free at brevo.com
# Then: SMTP & API → SMTP → Generate SMTP Key
BREVO_SMTP_LOGIN=your-brevo-account-email@gmail.com
BREVO_SMTP_KEY=xsmtpsib-...

# ── Gmail fallback (only if not using Brevo) ──
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Dashboard URL ──
DASHBOARD_URL=https://careerai-production-bc1b.up.railway.app

# ── Tally Webhook Secret (optional) ──
TALLY_WEBHOOK_SECRET=rolecraft-tally-secret-2025
